# Copy to .env and fill in your values.

# Anthropic API key (required)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Azure Bot registration
MicrosoftAppId=""

# Auth option A — client secret (if your Entra tenant allows it):
MicrosoftAppPassword=""

# Auth option B — certificate (use if client secrets are blocked by tenant policy):
# Generate with: openssl req -newkey rsa:2048 -nodes -keyout bot.key -x509 -days 730 -out bot.cer -subj "/CN=zt-scribe-bot"
# Upload bot.cer to Azure → App Registration → Certificates & secrets → Certificates tab
# Copy the thumbprint shown after upload
MicrosoftCertThumbprint=""
MicrosoftCertKeyFile="bot.key"

# Only needed for single-tenant apps (most bots are MultiTenant):
# MicrosoftAppType="SingleTenant"
# MicrosoftAppTenantId=""
